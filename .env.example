# ============================================================
# Ogak SMS AI — Environment Variables
# Copy to .env and fill in real values before deploying.
# NEVER commit .env to git.
# ============================================================

# ── SMS Aggregator ─────────────────────────────────────────
# Which aggregator to use: hollatags | arkesel | infotek
AGGREGATOR=hollatags

# API key from your aggregator dashboard
AGGREGATOR_API_KEY=REPLACE_WITH_YOUR_HOLLATAGS_API_KEY

# Approved sender ID registered with your aggregator
AGGREGATOR_SENDER=OGAK

# Your dedicated shortcode
SHORTCODE=55555

# ── LLM Backend ────────────────────────────────────────────
# ollama (local, single machine) or vllm (high-throughput cluster)
LLM_BACKEND=ollama

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# vLLM server URL (used when LLM_BACKEND=vllm)
VLLM_BASE_URL=http://localhost:8000

# Model name — must be pulled in Ollama or loaded in vLLM
# Options: llama3.1:8b | gemma2:9b | n-atlas-v1
LLM_MODEL=llama3.1:8b

# ── Telemetry ──────────────────────────────────────────────
# Path for JSON-lines telemetry file
TELEMETRY_LOG_PATH=telemetry.jsonl

# Optional: Supabase (leave blank to disable)
SUPABASE_URL=
SUPABASE_KEY=

# ── Security ──────────────────────────────────────────────────────
# HMAC-SHA256 secret — agree this value with your aggregator (HollaTags/Arkesel)
# Leave blank in dev; MUST set in production.
WEBHOOK_SECRET=REPLACE_WITH_SHARED_SECRET   # <-- CONFIRM with aggregator

# ── NDPR Opt-out ─────────────────────────────────────────────────
OPTOUT_FILE=/data/optout.json
SEEN_USERS_FILE=/data/seen_users.json

# ── App ──────────────────────────────────────────────────────────
# Set to "production" to disable /test/sms endpoint
ENV=dev

# Port FastAPI listens on (Railway sets PORT automatically)
PORT=8000
